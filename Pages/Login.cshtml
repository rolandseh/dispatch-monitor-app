@page
@model MyModernWebApp.Pages.LoginModel
@{
    ViewData["Title"] = "Login";
}

<div class="container mt-5" style="max-width: 400px;">
    <h2>Login</h2>
    
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert ale rt-danger">@Model.ErrorMessage</div>
    }

    <div class="text-center mb-4">
        <img src="~/images/advent-law-corporation.png" alt="Company Logo" class="img-fluid" style="max-height: 80px;" />
        <h3 class="mt-3">System Secure Login</h3>
    </div>

    <form method="post">
        <div class="mb-3">
            <label class="form-label">Username</label>
            <input type="text" name="username" class="form-control" required />
        </div>
        <div class="mb-3">
            <label class="form-label">Password</label>
            <input type="password" name="password" class="form-control" required />
        </div>
        <button type="submit" class="btn btn-primary">Login</button>
    </form>
</div>