@page
@model MyModernWebApp.Pages.LoginModel
@{
    ViewData["Title"] = "Secure Portal Sign In";
}

<!-- Modern Elegant Toast Notification Container (Upper Right) -->
<div class="toast-container position-fixed top-0 end-0 p-4" style="z-index: 1055;">
    <div id="errorToast" class="card border-0 shadow-lg @(!string.IsNullOrEmpty(Model.ErrorMessage) ? "show" : "hide")" role="alert" aria-live="assertive" aria-atomic="true" style="display: @(!string.IsNullOrEmpty(Model.ErrorMessage) ? "block" : "none"); border-radius: 12px; width: 360px; background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(8px);">
        <div class="card-body p-3 border-start border-4 border-danger d-flex align-items-center gap-3">
            <div class="bg-danger bg-opacity-10 p-2.5 rounded-3 text-danger">
                <i class="bi bi-shield-exclamation fs-5"></i>
            </div>
            <div class="flex-grow-1">
                <h6 class="mb-0 fw-bold text-dark" style="letter-spacing: -0.02em;">Security Alert</h6>
                <p class="mb-0 small text-secondary">@Model.ErrorMessage</p>
            </div>
            <button type="button" class="btn-close ms-auto align-self-start" data-bs-dismiss="toast" aria-label="Close" onclick="closeToast()"></button>
        </div>
    </div>
</div>

<!-- Full Screen Master Split Layout Shell -->
<div class="container-fluid p-0 min-vh-100 d-flex flex-column flex-md-row bg-white overflow-hidden">
    
    <!-- 1. Left Side Panel: Grand Corporate Branding Canvas -->
    <div class="col-md-5 col-lg-6 bg-dark position-relative d-flex flex-column justify-content-between p-5 text-white" style="background: linear-gradient(135deg, #111315 0%, #1a1e22 50%, #23292f 100%);">
        
        <!-- Abstract Structural Mesh / Sophisticated Background Accent Overlay -->
        <div class="position-absolute top-0 start-0 w-100 h-100 opacity-10 pointer-events-none" style="background-image: radial-gradient(rgba(255,255,255,0.15) 1px, transparent 1px); background-size: 24px 24px;"></div>
        
        <!-- Top Accents -->
        <div class="position-relative d-flex align-items-center gap-2">
            <span class="badge bg-info bg-opacity-10 text-info px-3 py-2 border border-info border-opacity-20 rounded-pill small fw-semibold tracking-wider text-uppercase" style="font-size: 0.7rem;">
                <i class="bi bi-shield-lock-fill me-1"></i> Core Infrastructure v1.0
            </span>
        </div>

        <!-- Center Master Logo Container (Floating Grand Display) -->
        <div class="position-relative my-auto text-center py-5 py-md-0">
            <div class="logo-glow-wrapper mb-4 d-inline-block p-4 rounded-4 shadow-lg bg-white bg-opacity-5 border border-white border-opacity-10" style="backdrop-filter: blur(12px);">
                <img src="~/images/advent-law-corporation.png" alt="Advent Law Corporation" class="img-fluid object-fit-contain img-brightness-invert" style="max-width: 280px; filter: drop-shadow(0 0 20px rgba(13,202,240,0.15));" />
            </div>
            <h1 class="h2 fw-bold tracking-tight text-white mb-2" style="letter-spacing: -0.03em;">Dispatch Management Engine</h1>
            <p class="text-secondary opacity-75 mx-auto fs-6" style="max-width: 400px; font-weight: 300;">Real-time Service Report Dispatch Management.</p>
        </div>

        <!-- Footer Accent Data -->
        <div class="position-relative d-flex justify-content-between align-items-center small text-secondary border-top border-white border-opacity-10 pt-3 opacity-50">
            <span>&copy; 2026 Advent Law Corp.</span>
            <span>Secure Nodes Active <i class="bi bi-circle-fill text-success ms-1 small" style="font-size: 0.5rem;"></i></span>
        </div>
    </div>

    <!-- 2. Right Side Panel: Luxury Minimalist Authentication Dock -->
    <div class="col-md-7 col-lg-6 d-flex flex-column justify-content-center px-4 px-md-5 py-5 bg-light" style="background-color: #f8f9fa !important;">
        <div class="mx-auto w-100" style="max-width: 400px;">
            
            <!-- Welcome Header Block -->
            <div class="mb-4">
                <h2 class="h4 fw-bold text-dark mb-1" style="letter-spacing: -0.02em;">User Access</h2>
                <p class="text-secondary small">Provide authorized credentials to establish an authenticated session.</p>
            </div>

            <!-- Login Controls Execution Grid -->
            <form method="post" autocomplete="off">
                <div class="mb-3">
                    <label class="form-label text-secondary small fw-semibold tracking-wide text-uppercase" style="font-size: 0.7rem;">User Identity</label>
                    <div class="input-container position-relative">
                        <span class="position-absolute top-50 start-0 translate-middle-y ps-3 text-muted opacity-50"><i class="bi bi-person fs-5"></i></span>
                        <input type="text" name="Username" class="form-control luxury-input ps-5 py-2.5 shadow-sm" placeholder="Enter your User ID" required />
                    </div>
                </div>
                
                <div class="mb-4">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <label class="form-label text-secondary small fw-semibold tracking-wide text-uppercase mb-0" style="font-size: 0.7rem;">Password</label>
                    </div>
                    <div class="input-container position-relative">
                        <span class="position-absolute top-50 start-0 translate-middle-y ps-3 text-muted opacity-50"><i class="bi bi-key fs-5"></i></span>
                        <input type="password" name="Password" class="form-control luxury-input ps-5 py-2.5 shadow-sm" placeholder="••••••••••••" required />
                    </div>
                </div>

                <button type="submit" class="btn btn-dark w-100 py-2.5 rounded-3 fw-semibold shadow-sm tracking-wide text-uppercase luxury-btn d-flex align-items-center justify-content-center gap-2" style="background-color: #111315; border: none; font-size: 0.85rem;">
                    LOGON <i class="bi bi-arrow-right-short fs-5"></i>
                </button>
            </form>

        </div>
    </div>

</div>

@section Scripts {
    <script>
        // Auto-dismiss the toast interface wrapper smoothly after 5 seconds
        document.addEventListener("DOMContentLoaded", function () {
            const toastEl = document.getElementById('errorToast');
            if (toastEl && toastEl.style.display === "block") {
                setTimeout(() => { closeToast(); }, 5000);
            }
        });

        function closeToast() {
            const toastEl = document.getElementById('errorToast');
            if (toastEl) {
                toastEl.style.setProperty('display', 'none', 'important');
            }
        }
    </script>
}

<style>
    /* Premium Luxury CSS Tokens */
    .luxury-input {
        background-color: #ffffff !important;
        border: 1px solid #e2e8f0 !important;
        border-radius: 8px !important;
        font-size: 0.95rem;
        color: #1e293b !important;
        transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1) !important;
    }
    .luxury-input:focus {
        border-color: #0dcaf0 !important;
        box-shadow: 0 4px 12px rgba(13, 202, 240, 0.08), 0 0 0 3px rgba(13, 202, 240, 0.15) !important;
        background-color: #ffffff !important;
    }
    .luxury-input:focus + span,
    .input-container:focus-within span {
        color: #0dcaf0 !important;
        opacity: 1 !important;
    }
    .luxury-btn {
        transition: all 0.2s ease;
    }
    .luxury-btn:hover {
        background-color: #23292f !important;
        transform: translateY(-1px);
        box-shadow: 0 8px 16px rgba(0,0,0,0.1) !important;
    }
    .luxury-btn:active {
        transform: translateY(0);
    }
    
    /* Elegant inversion/glow parameters if branding image uses colors that benefit from dark layouts */
    .img-brightness-invert {
        filter: brightness(1) contrast(1);
    }
</style>