@page
@model MyModernWebApp.Pages.MonitorModel
@{
    ViewData["Title"] = "Dispatch Monitor";
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-md-6">
            <h4 class="p-2 text-center" style="background-color: #e9ecef;">Current Day Dispatch</h4>
            <div class="table-responsive">
                <table class="table table-striped table-bordered table-sm font-monospace">
                    <thead class="table-primary text-white">
                        <tr>
                            <th>Case Ref Number</th>
                            <th>Debtor's Name</th>
                            <th>Address</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.CurrentDayDispatch != null && Model.CurrentDayDispatch.Any())
                        {
                            @foreach (var row in Model.CurrentDayDispatch)
                            {
                                <tr>
                                    <td>@row.CaseRefNo</td>
                                    <td>@row.DebtorName</td>
                                    <td>@row.DebtorAddr</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="3" class="text-center text-muted">No dispatches for today.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="col-md-6">
            <h4 class="p-2 text-center" style="background-color: #e9ecef;">Overdue Dispatch</h4>
            <div class="table-responsive">
                <table class="table table-striped table-bordered table-sm font-monospace">
                    <thead class="table-primary text-white">
                        <tr>
                            <th>Case Ref Number</th>
                            <th>Debtor's Name</th>
                            <th>Address</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.OverdueDispatch != null && Model.OverdueDispatch.Any())
                        {
                            @foreach (var row in Model.OverdueDispatch)
                            {
                                <tr>
                                    <td>@row.CaseRefNo</td>
                                    <td>@row.DebtorName</td>
                                    <td>@row.DebtorAddr</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="3" class="text-center text-muted">No overdue dispatches.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>