using Microsoft.AspNetCore.Mvc;
using Microsoft.AspNetCore.Mvc.RazorPages;

namespace MyModernWebApp.Pages
{
    public class IndexModel : PageModel
    {
        // 1. Make sure it returns IActionResult so it can handle redirects
        public IActionResult OnGet()
        {
        if (User.Identity == null || !User.Identity.IsAuthenticated)
            {
                return RedirectToPage("/Login");
            }

            // If they ARE logged in, forward them straight to your real Monitor dashboard page safely!
            return RedirectToPage("/Monitor");
        }
    }
}