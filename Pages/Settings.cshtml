@page
@model MyModernWebApp.Pages.SettingsModel
@{
    ViewData["Title"] = "System Settings";
}

<div class="container-fluid max-width-xl mt-4 px-4">
    
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <div>
            <h1 class="h3 mb-1 text-dark fw-bold">⚙️ System Configuration</h1>
            <p class="text-muted small mb-0">Manage user authorization records and postal delivery sectors.</p>
        </div>
        
        <div class="btn-group shadow-sm" role="group" aria-label="Panel Navigation">
            <button type="button" id="btn-tab-users" class="btn btn-dark active" onclick="showPanel('users')">
                👤 User Management
            </button>
            <button type="button" id="btn-tab-postal" class="btn btn-outline-secondary" onclick="showPanel('postal')">
                📍 Postal Management
            </button>
        </div>
    </div>

    <div id="panel-users" class="card shadow-sm border-0 mb-5">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 text-nowrap">
                    <thead class="table-dark">
                        <tr>
                            <th style="width: 120px;">User ID</th>
                            <th style="width: 280px;">Full Name</th>
                            <th style="width: 160px;">Password</th>
                            <th style="width: 120px;">Admin Status</th>
                            <th style="width: 180px;">Assigned Device</th>
                            <th style="width: 120px;">Account Status</th>
                            <th class="text-center" style="width: 140px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.UsersList.Any())
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted py-4">No user records currently registered in system database.</td>
                            </tr>
                        }
                        else
                        {
                             @foreach (var user in Model.UsersList)
{
    if (Model.EditingUsername == user.Username)
    {
        <tr class="table-info">
            <form method="post" asp-page-handler="UpdateUser">
                <input type="hidden" name="EditUser.Username" value="@user.Username" />
                
                <td class="fw-bold text-dark align-middle">@user.Username</td>
                <td>
                    <input type="text" name="EditUser.Name" class="form-control form-control-sm" value="@user.Name" required />
                </td>
                <td>
                    <input type="password" name="EditUser.Passwd" class="form-control form-control-sm" placeholder="Leave blank to keep current" />
                </td>
                <td>
                    <select name="EditUser.Admin" class="form-select form-select-sm">
                        <option value="false" selected="@(!user.Admin)">No</option>
                        <option value="true" selected="@user.Admin)">Yes</option>
                    </select>
                </td>
                <td>
                    <input type="text" name="EditUser.DeviceId" class="form-control form-control-sm" value="@user.DeviceId" />
                </td>
                <td>
                    <select name="EditUser.Enabled" class="form-select form-select-sm">
                        <option value="true" selected="@user.Enabled">Enabled</option>
                        <option value="false" selected="@(!user.Enabled)">Disabled</option>
                    </select>
                </td>
                <td class="text-center">
                    <div class="btn-group btn-group-sm">
                        <button type="submit" class="btn btn-success btn-sm">Save</button>
                        <a asp-page="/Settings" asp-route-activeTab="users" class="btn btn-outline-secondary btn-sm">Cancel</a>
                    </div>
                </td>
            </form>
        </tr>
    }
    else
    {
        <tr>
            <td class="fw-bold text-dark">@user.Username</td>
            <td>@user.Name</td>
            <td class="text-muted font-monospace small">••••••••</td>
            <td>
                <span class="badge rounded-pill @(user.Admin ? "bg-success-subtle text-success border border-success-subtle" : "bg-secondary-subtle text-secondary") px-2 py-1">
                    @(user.Admin ? "Yes" : "No")
                </span>
            </td>
            <td class="text-secondary small font-monospace">@(string.IsNullOrEmpty(user.DeviceId) ? "-" : user.DeviceId)</td>
            <td>
                <span class="badge rounded-pill @(user.Enabled ? "bg-info-subtle text-info border border-info-subtle" : "bg-danger-subtle text-danger border border-danger-subtle") px-2 py-1">
                    @(user.Enabled ? "Enabled" : "Disabled")
                </span>
            </td>
            <td class="text-center">
                <div class="btn-group btn-group-sm">
                    <a asp-page="/Settings" asp-route-editUsername="@user.Username" asp-route-activeTab="users" class="btn btn-outline-secondary btn-sm">Edit</a>
                    
                    <form method="post" asp-page-handler="DeleteUser" asp-route-username="@user.Username" onsubmit="return confirm('Permanently remove this user account?');" class="d-inline">
                        <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
                    </form>
                </div>
            </td>
        </tr>
    }
}                           
                        }
                        
                        <tr class="table-inline-add">
                            <form method="post" asp-page-handler="AddUser">
                                <td>
                                    <input type="text" name="NewUser.Username" class="form-control form-control-sm border-secondary-subtle" placeholder="New ID" required />
                                </td>
                                <td>
                                    <input type="text" name="NewUser.Name" class="form-control form-control-sm border-secondary-subtle" placeholder="Display Name" required />
                                </td>
                                <td>
                                    <input type="password" name="NewUser.Passwd" class="form-control form-control-sm border-secondary-subtle" placeholder="Password" required />
                                </td>
                                <td>
                                    <select name="NewUser.Admin" class="form-select form-select-sm border-secondary-subtle">
                                        <option value="false">No</option>
                                        <option value="true">Yes</option>
                                    </select>
                                </td>
                                <td>
                                    <input type="text" name="NewUser.DeviceId" class="form-control form-control-sm border-secondary-subtle" placeholder="Device Registration Key" />
                                </td>
                                <td>
                                    <select name="NewUser.Enabled" class="form-select form-select-sm border-secondary-subtle">
                                        <option value="true" selected>Enabled</option>
                                        <option value="false">Disabled</option>
                                    </select>
                                </td>
                                <td class="text-center">
                                    <button type="submit" class="btn btn-sm btn-primary w-100 fw-bold shadow-sm">➕ Save Account</button>
                                </td>
                            </form>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div id="panel-postal" class="card shadow-sm border-0 mb-5" style="display: none;">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 text-nowrap">
                <thead class="table-dark">
                    <tr>
                        <th style="width: 80px;">ID</th>
                        <th style="width: 150px;">District Group</th>
                        <th style="width: 150px;">Routing Sector</th>
                        <th>Geographic Location Details</th>
                        <th class="text-center" style="width: 180px;">Operational Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.PostalList.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">No postal sector maps currently stored in dataset.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var post in Model.PostalList)
                        {
                            if (Model.EditingPostalId == post.Id)
                            {
                                <tr class="table-info">
                                    <form method="post" asp-page-handler="UpdatePostal">
                                        <input type="hidden" name="EditPostal.Id" value="@post.Id" />
                                        <td class="font-monospace small text-muted">#@post.Id</td>
                                        <td>
                                            <input type="text" name="EditPostal.District" class="form-control form-control-sm" value="@post.District" required />
                                        </td>
                                        <td>
                                            <input type="text" name="EditPostal.Sector" class="form-control form-control-sm" value="@post.Sector" required />
                                        </td>
                                        <td>
                                            <input type="text" name="EditPostal.Location" class="form-control form-control-sm" value="@post.Location" required />
                                        </td>
                                        <td class="text-center">
                                            <div class="btn-group btn-group-sm">
                                                <button type="submit" class="btn btn-success btn-sm">Save</button>
                                                <a asp-page="/Settings" asp-route-activeTab="postal" class="btn btn-outline-secondary btn-sm">Cancel</a>
                                            </div>
                                        </td>
                                    </form>
                                </tr>
                            }
                            else
                            {
                                <tr>
                                    <td class="text-secondary font-monospace small">#@post.Id</td>
                                    <td><span class="badge bg-light text-dark border px-2 py-1">District @post.District</span></td>
                                    <td class="font-monospace fw-bold text-primary">@post.Sector</td>
                                    <td class="text-wrap text-dark" style="max-width: 500px;">@post.Location</td>
                                    <td class="text-center">
                                        <div class="btn-group btn-group-sm">
                                            <a asp-page="/Settings" asp-route-editPostalId="@post.Id" asp-route-activeTab="postal" class="btn btn-outline-secondary btn-sm">Edit</a>
                                            <form method="post" asp-page-handler="DeletePostal" asp-route-id="@post.Id" onsubmit="return confirm('Permanently wipe this routing sector map out?');" class="d-inline">
                                                <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    }

                    <tr class="table-inline-add">
                        <form method="post" asp-page-handler="AddPostal">
                            <td class="text-muted font-monospace small text-center align-middle">✨</td>
                            <td>
                                <input type="text" name="NewPostal.District" class="form-control form-control-sm border-secondary-subtle" placeholder="District" required />
                            </td>
                            <td>
                                <input type="text" name="NewPostal.Sector" class="form-control form-control-sm border-secondary-subtle" placeholder="Sector Key" required />
                            </td>
                            <td>
                                <input type="text" name="NewPostal.Location" class="form-control form-control-sm border-secondary-subtle" placeholder="Full Geographical Details" required />
                            </td>
                            <td class="text-center">
                                <button type="submit" class="btn btn-sm btn-primary w-100 fw-bold shadow-sm">➕ Add Sector</button>
                            </td>
                        </form>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

</div>

<script>
    window.addEventListener('DOMContentLoaded', () => {
        const urlParams = new URLSearchParams(window.location.search);
        const activeTab = urlParams.get('activeTab') || 'users';
        showPanel(activeTab);
    });

    function showPanel(panelKey) {
        const usersPanel = document.getElementById('panel-users');
        const postalPanel = document.getElementById('panel-postal');
        const usersBtn = document.getElementById('btn-tab-users');
        const postalBtn = document.getElementById('btn-tab-postal');

        if (panelKey === 'users') {
            usersPanel.style.display = 'block';
            postalPanel.style.display = 'none';
            usersBtn.className = "btn btn-dark active";
            postalBtn.className = "btn btn-outline-secondary";
        } else {
            usersPanel.style.display = 'none';
            postalPanel.style.display = 'block';
            usersBtn.className = "btn btn-outline-secondary";
            postalBtn.className = "btn btn-dark active";
        }
    }
</script>

    </div>
</div>

<script>
    function showPanel(panelKey) {
        const usersPanel = document.getElementById('panel-users');
        const postalPanel = document.getElementById('panel-postal');
        const usersBtn = document.getElementById('btn-tab-users');
        const postalBtn = document.getElementById('btn-tab-postal');

        if (panelKey === 'users') {
            usersPanel.style.display = 'block';
            postalPanel.style.display = 'none';
            
            usersBtn.className = "btn btn-dark active";
            postalBtn.className = "btn btn-outline-secondary";
        } else {
            usersPanel.style.display = 'none';
            postalPanel.style.display = 'block';
            
            usersBtn.className = "btn btn-outline-secondary";
            postalBtn.className = "btn btn-dark active";
        }
    }
</script>